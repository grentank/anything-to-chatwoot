# ---------------------------------------------------------------------------
# anything-to-chatwoot configuration
# Copy to .env and fill in the values. Secrets must never be committed.
# ---------------------------------------------------------------------------

# --- App ---
NODE_ENV=production
PORT=3000
# error | warn | log | debug | verbose
LOG_LEVEL=log
# Forward Chatwoot system/activity messages (agent joined, conversation resolved)
# to the messenger. Most setups want this off.
FORWARD_SYSTEM_MESSAGES=false

# --- Chatwoot ---
# Base URL of your self-hosted Chatwoot, no trailing slash.
CHATWOOT_BASE_URL=https://chatwoot.example.com
# Agent/Bot access token (Profile Settings -> Access Token, or an Agent Bot token).
CHATWOOT_API_ACCESS_TOKEN=your-chatwoot-access-token
# Numeric account id (visible in the Chatwoot dashboard URL).
CHATWOOT_ACCOUNT_ID=1
# Optional HMAC secret to verify incoming Chatwoot webhooks. Leave empty to disable.
CHATWOOT_WEBHOOK_SECRET=

# --- Telegram ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Id of the Chatwoot API-channel inbox that represents this Telegram bot.
TELEGRAM_INBOX_ID=1
# polling (default, simplest) or webhook.
TELEGRAM_MODE=polling
# Required only in webhook mode: public https URL of this service.
TELEGRAM_WEBHOOK_DOMAIN=
# Optional secret token Telegram echoes back on each webhook call.
TELEGRAM_WEBHOOK_SECRET=
