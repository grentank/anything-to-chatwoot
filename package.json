{
  "name": "anything-to-chatwoot",
  "version": "0.1.0",
  "description": "Lightweight bridge that relays messages between messengers (Telegram first) and a Chatwoot API-channel inbox in both directions.",
  "author": "grentank",
  "license": "MIT",
  "private": false,
  "main": "dist/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.8",
    "@swc/core": "^1.13.5",
    "@types/node": "^22.18.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "unplugin-swc": "^1.5.7",
    "vitest": "^2.1.9"
  }
}
